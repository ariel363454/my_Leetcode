class Solution {
public:
    void setZeroes(vector<vector<int>>& matrix) {
        set<int> r;
        set<int> c;
        for(int i = 0;i < matrix.size();i++){
            for(int j = 0;j < matrix[0].size();j++){
                if(matrix[i][j] == 0){
                    r.insert(i);
                    c.insert(j);
                }
            }
        }
        while(!r.empty()){
            for(int j = 0;j < matrix[0].size();j++)
                matrix[*r.begin()][j] = 0;
            r.erase(*r.begin());
        }
        while(!c.empty()){
            for(int i = 0;i < matrix.size();i++)
                matrix[i][*c.begin()] = 0;
            c.erase(*c.begin());
        }
    }
};
