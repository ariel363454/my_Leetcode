class Solution {
public:
    string addBinary(string a, string b) {
        string ans = "";
        int carry = 0;
        int i = a.size() - 1;
        int j = b.size() - 1;
        while(i >= 0 || j >= 0){
            int sum;
            if(i < 0)
                sum = b[j] + carry - 48;
            else if(j < 0)
                sum = a[i] + carry - 48;
            else
                sum = a[i] + b[j] + carry - 96;
            if(sum == 3){
                ans = "1" + ans;
                carry = 1;
            }else if(sum == 2){
                ans = "0" + ans;
                carry = 1;
            }else{
                ans = to_string(sum) + ans;
                carry = 0;
            }
            i--;
            j--;
            cout << ans << endl;
        }
        if(carry == 1)
            ans = "1" + ans;
        return ans;
    }
};
