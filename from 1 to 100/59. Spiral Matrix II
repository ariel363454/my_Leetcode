class Solution {
public:
    vector<vector<int>> generateMatrix(int n) {
        vector<vector<int>> ans(n, vector<int>(n, 0));
        if(n == 0)
            return ans;
        int up = 0;
        int left = 0;
        int down = n - 1;
        int right = n - 1;
        int num = 1;
        while(num){
            for(int j = left;j <= right;j++){
                ans[up][j] = num;
                num++;
            }
            up++;
            if(up > down)
                break;
            for(int i = up;i <= down;i++){
                ans[i][right] = num;
                num++;
            }
            right--;
            if(left > right)
                break;
            for(int j = right;j >= left;j--){
                ans[down][j] = num;
                num++;
            }
            down--;
            if(up > down)
                break;
            for(int i = down;i >= up;i--){
                ans[i][left] = num;
                num++;
            }
            left++;
            if(left > right)
                break;
        }
        return ans;
    }
};
