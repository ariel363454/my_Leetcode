class Solution {
public:
    vector<int> plusOne(vector<int>& digits) {
        if(digits.back() != 9){
            digits.back()++;
            return digits;
        }else{
            int carry = 1;
            for(int i = digits.size()-1;carry == 1;i--){
                if(digits[i] == 9){
                    if(i == 0){
                        digits.insert(digits.begin(), 0);
                        i++;
                    }
                    digits[i] = 0;
                }else{
                    digits[i] += 1;
                    carry = 0;
                }
            }
            return digits;
        }
    }
};
